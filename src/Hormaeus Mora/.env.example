MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=
NEXTCLOUD_ADMIN_USER=
NEXTCLOUD_ADMIN_PASSWORD=
# Must include the Tailscale hostname it is served under.
NEXTCLOUD_TRUSTED_DOMAINS=lenovoflakes.tail62b305.ts.net
# Subnet nginx (Norcturnal) connects from on the Oblivion network.
# Find it with: docker network inspect Oblivion  (look at IPAM.Config.Subnet)
NEXTCLOUD_TRUSTED_PROXIES=172.16.0.0/12
